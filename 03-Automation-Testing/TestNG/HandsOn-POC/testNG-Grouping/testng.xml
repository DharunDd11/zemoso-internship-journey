<?xml version="1.0" encoding="UTF-8"?>

<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Grouping Suite">

    <test name="Include Exclude Example">

        <groups>
            <run>
                <include name="smoke"/>
                <include name="sanity"/>
                <exclude name="regression"/>
            </run>
        </groups>

        <classes>
            <class name="org.example.GroupingExample"/>
        </classes>

    </test>

</suite>